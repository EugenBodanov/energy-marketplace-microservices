# Environment Configuration Files
# Copy the appropriate file to .env and docker will load it automatically

# LOCAL DEVELOPMENT (.env.local)
# Use: docker-compose --env-file .env.local up
SPRING_PROFILES_ACTIVE=default
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
LISTING_SERVICE_PORT=8082
TRADE_SERVICE_PORT=8083
USER_DB_PORT=5432
LISTING_DB_PORT=5433
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

---

# DOCKER COMPOSE (.env.docker)
# Use: docker-compose --env-file .env.docker up
SPRING_PROFILES_ACTIVE=docker
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
LISTING_SERVICE_PORT=8082
TRADE_SERVICE_PORT=8083

---

# GOOGLE CLOUD (.env.cloud)
# Set manually or in Cloud Run environment
SPRING_PROFILES_ACTIVE=cloud
CLOUD_PROJECT_ID=your-project-id

